# ============================================================
# Maji Watch — .gitignore
# ============================================================

# --- Environment Variables (NEVER commit these) ---
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# --- Node ---
node_modules/
backend/node_modules/
frontend/node_modules/

# --- Build Output ---
dist/
backend/dist/
frontend/dist/

# --- Logs ---
*.log
logs/
backend/logs/

# --- Uploads (local dev only) ---
backend/uploads/
*.jpg
*.jpeg
*.png
*.webp

# --- TypeScript ---
*.tsbuildinfo

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Testing ---
coverage/
.nyc_output/

# --- Misc ---
.cache/
tmp/
