# =============================================================
# MAJI WATCH — Environment Variables
# =============================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# =============================================================

# --- Server ---
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# --- PostgreSQL / Supabase ---
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=true

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars //@candice-wanjiru-mwaura-2017-2025
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# --- File Uploads ---
# Options: "local" | "supabase_storage" | "cloudinary"
STORAGE_PROVIDER=supabase_storage
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Supabase Storage (if STORAGE_PROVIDER=supabase_storage)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=report-images

# Local storage fallback
LOCAL_UPLOAD_PATH=./uploads

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# --- Logging ---
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/app.log

# --- Admin Seed ---
# Used only during initial DB setup
SEED_ADMIN_EMAIL=admin@county.go.ke
SEED_ADMIN_PASSWORD=Change_This_Immediately_2024! //@Candice2017!
